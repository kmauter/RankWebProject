# Required — app will crash without this
SECRET_KEY="your-secret-key-here"

# Database — defaults to SQLite at project root if not set
# DATABASE_URL="postgresql://user:password@localhost:5432/rankwebdb"

# Spotify OAuth (required for playlist creation)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_REDIRECT_URI="http://127.0.0.1:5000/api/spotifycallback"

# YouTube OAuth (required for playlist creation)
YOUTUBE_CLIENT_ID="your-youtube-client-id"
YOUTUBE_CLIENT_SECRET="your-youtube-client-secret"
YOUTUBE_REDIRECT_URI="http://127.0.0.1:5000/api/youtubecallback"

# Discord Bot Webhook Notification (optional — enables stage transition notifications to the bot)
BOT_NOTIFY_URL="http://localhost:8080/notify"
BOT_NOTIFY_SECRET="your-shared-secret-token"

# Discord Bot (required to run the bot process via `python -m bot.main`)
DISCORD_BOT_TOKEN="your-discord-bot-token"
FLASK_API_URL="http://localhost:5000"
BOT_HTTP_PORT="8080"
